<!doctype html>
<html lang="en" class="h-full">
<%- include('../partials/document-head', { title: 'MagickMonkey' }) %>
  <body class="m-0 h-full overflow-hidden bg-mm-canvas p-0 antialiased">
    <mm-popup-app>
      <div class="mm-shell mm-popup-shell w-[300px] overflow-hidden" data-ref="popup-shell">
        <div data-ref="main-view">
          <header class="mm-popup-header flex shrink-0 items-center gap-3 border-b border-mm-border-light bg-mm-surface px-3 py-3 shadow-mm-sm">
            <img src="./icons/icon32.png" width="32" height="32" alt="" class="h-8 w-8 shrink-0 rounded-lg shadow-mm-sm ring-1 ring-mm-border-light" />
            <div class="min-w-0 flex-1">
              <div class="font-semibold leading-tight tracking-tight text-mm-ink">MagickMonkey</div>
              <div class="truncate text-xs text-mm-text-muted" data-ref="subtitle">Not configured</div>
            </div>
            <div class="flex shrink-0 items-center gap-[2px]">
              <div class="relative shrink-0">
                <button type="button" data-action="shell-master" title="Extension enabled" class="mm-icon-btn" aria-haspopup="menu" aria-expanded="false">
                  <span data-ref="shell-master-icon" data-icon="serviceOn" class="mm-icon-slot"></span>
                </button>
                <div data-ref="shell-disable-menu" class="mm-shell-disable-menu hidden" role="menu" aria-label="Extension">
                  <button type="button" data-action="shell-disable-tab" role="menuitem" class="mm-shell-disable-menu-item">This tab only</button>
                  <button type="button" data-action="shell-disable-all" role="menuitem" class="mm-shell-disable-menu-item">All tabs</button>
                  <div class="mm-shell-disable-menu-divider" role="separator" aria-hidden="true"></div>
                  <button type="button" data-action="shell-reload" role="menuitem" class="mm-shell-disable-menu-item">Reload extension</button>
                </div>
              </div>
              <button type="button" data-action="options" title="Servers" class="mm-icon-btn">
                <span data-icon="settings" class="mm-icon-slot"></span>
              </button>
            </div>
          </header>

          <div class="space-y-2.5 p-3">
            <div class="mm-card divide-y divide-mm-border-light">
              <button type="button" data-action="update" class="mm-row-btn">
                <span data-icon="refresh"></span>
                <span>Update runtime</span>
              </button>
              <button type="button" data-action="sync-rules" class="mm-row-btn">
                <span data-icon="sync"></span>
                <span>Sync rules from server</span>
              </button>
              <div class="h-px bg-mm-canvas" aria-hidden="true"></div>
              <button type="button" data-action="reset" class="mm-row-btn-danger">
                <span data-icon="reset" class="mm-icon-slot mm-row-icon-danger"></span>
                <span>Reset runtime state</span>
              </button>
            </div>

            <div class="mm-card">
              <label class="mm-switch-row">
                <span class="flex min-w-0 items-center gap-2.5">
                  <span data-icon="network"></span>
                  <span class="text-[13px] text-mm-secondary">Shell network</span>
                </span>
                <span class="mm-switch">
                  <input type="checkbox" data-ref="network" class="mm-switch-input" role="switch" />
                  <span class="mm-switch-track" aria-hidden="true"></span>
                  <span class="mm-switch-thumb" aria-hidden="true"></span>
                </span>
              </label>
              <div class="h-px bg-mm-canvas" aria-hidden="true"></div>
              <div class="mm-popup-settings-row">
                <span class="flex min-w-0 items-center gap-2.5">
                  <span data-icon="logs" aria-hidden="true"></span>
                  <span class="text-[13px] text-mm-secondary">Logger</span>
                </span>
                <nav class="mm-admin-nav mm-popup-log-nav is-indicator-ready" data-ref="log-output-tabs" role="tablist" aria-label="Logger output">
                  <button type="button" role="tab" class="mm-admin-nav-link" data-log-mode="console" aria-current="page">Console</button>
                  <button type="button" role="tab" class="mm-admin-nav-link" data-log-mode="logviewer">Viewer</button>
                  <button type="button" role="tab" class="mm-admin-nav-link" data-log-mode="none">Off</button>
                </nav>
              </div>
            </div>

            <div class="mm-card divide-y divide-mm-border-light">
              <button type="button" data-action="scripts" class="mm-row-btn">
                <span data-icon="scripts"></span>
                <span>Manage scripts</span>
              </button>
              <button type="button" data-action="rules-page" class="mm-row-btn">
                <span data-icon="rulesManage"></span>
                <span>Manage local rules</span>
              </button>
              <div class="h-px bg-mm-canvas" aria-hidden="true"></div>
              <button type="button" data-action="rules" class="mm-row-btn">
                <span data-icon="quickRules"></span>
                <span>Quick add local rule</span>
              </button>
              <button type="button" data-action="open-agent" class="mm-row-btn">
                <span data-icon="agent"></span>
                <span>Open Agent</span>
              </button>
            </div>
          </div>

          <footer class="mm-footer mm-popup-footer" data-ref="footer">
            <p class="mm-popup-footer-version">
              <span data-ref="version" class="mm-popup-footer-version-text">Preset v<%= projectVersion %> · Extension v<%= extensionVersion %></span><button type="button" class="mm-popup-footer-update hidden" data-ref="extension-update" title="Download latest extension">(新版本)</button>
            </p>
          </footer>
        </div>

        <div data-ref="rules-view" class="mm-popup-rules-view hidden flex h-full min-h-0 flex-col bg-white">
          <header class="flex items-center gap-2 border-b border-mm-border-light bg-mm-surface px-2 py-2 shadow-mm-sm">
            <button type="button" data-action="rules-back" class="mm-icon-btn" title="Back">
              <span data-icon="close" class="mm-icon-slot"></span>
            </button>
            <div class="text-[13px] font-semibold leading-none text-mm-ink">Quick add local rule</div>
          </header>
          <div class="flex flex-1 min-h-0 flex-col p-2.5">
            <div class="space-y-2">
              <div class="grid grid-cols-2 gap-2">
<%- include('../partials/rule-mode-select', { variant: 'inline', dataRef: 'quick-mode' }) %>
<%- include('../partials/rule-template-select', { variant: 'inline', dataRef: 'quick-template' }) %>
              </div>
              <mm-input><input data-ref="quick-pattern" type="text" placeholder="*://example.com/*" /></mm-input>
              <mm-search-select data-ref="quick-script"></mm-search-select>
            </div>
            <div class="mt-auto pt-2">
              <button type="button" data-action="quick-add-rule" class="mm-primary-btn">Add local rule</button>
            </div>
          </div>
        </div>
        <!--
          Popup toast overlay (see .mm-popup-toast in tailwind.css).
          Must stay a direct child of mm-shell (position:relative), not inside main-view.
          Use absolute bottom-0 only — position:fixed breaks Chrome extension popups.
          Do not reserve layout space (no padding-bottom on footer/shell when visible).
        -->
        <p data-ref="toast" class="mm-toast mm-popup-toast" role="status" aria-live="polite"></p>
      </div>
    </mm-popup-app>
    <script src="./popup.js"></script>
  </body>
</html>
