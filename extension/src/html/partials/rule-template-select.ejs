<%
  const ref = typeof dataRef !== 'undefined' ? dataRef : 'template';
  const isField = typeof variant !== 'undefined' && variant === 'field';
%>
<% if (isField) { %>
                        <mm-field class="mm-options-field">
                          <label<% if (typeof id !== 'undefined' && id) { %> for="<%= id %>"<% } %> class="mm-label"><%= label || 'Pattern template' %></label>
<% } %>
                          <mm-select<% if (typeof id !== 'undefined' && id) { %> id="<%= id %>"<% } %>>
                            <input type="hidden" data-ref="<%= ref %>" value="host" />
                            <button type="button" class="mm-select-trigger" data-ref="select-trigger" aria-haspopup="listbox" aria-expanded="false">
                              <span class="mm-select-value" data-ref="select-value">Current Host</span>
                              <%- include('mm-select-chevron') %>
                            </button>
                            <div class="mm-select-menu" role="listbox">
                              <button type="button" class="mm-select-option" data-value="host" aria-selected="true">Current Host</button>
                              <button type="button" class="mm-select-option" data-value="path" aria-selected="false">Current Path</button>
                              <button type="button" class="mm-select-option" data-value="exact" aria-selected="false">Exact URL</button>
                              <button type="button" class="mm-select-option" data-value="custom" aria-selected="false">Custom</button>
                            </div>
                          </mm-select>
<% if (isField && typeof hint !== 'undefined' && hint) { %>
                          <p class="mm-hint"><%= hint %></p>
                        </mm-field>
<% } %>
