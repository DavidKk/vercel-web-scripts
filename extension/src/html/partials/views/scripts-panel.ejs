        <div class="mm-scripts-main">
          <div class="mm-scripts-head">
            <div class="mm-scripts-head-copy">
              <h2 class="mm-servers-pane-title">Scripts</h2>
              <p class="mm-servers-pane-desc">Install scripts to use them (enabled by default). Uninstalled scripts stay listed at the bottom.</p>
            </div>
            <div class="mm-scripts-toolbar mm-scripts-toolbar-skeleton" data-ref="toolbar-skeleton" aria-hidden="true">
              <span class="mm-skeleton mm-skeleton-status"></span>
              <span class="mm-skeleton mm-skeleton-search"></span>
              <span class="mm-skeleton mm-skeleton-filter"></span>
              <span class="mm-skeleton mm-skeleton-filter"></span>
            </div>
            <div class="mm-panel-toolbar mm-scripts-toolbar" data-ref="toolbar">
              <mm-input>
                <span class="mm-input-icon" aria-hidden="true">
                  <svg viewBox="0 0 20 20" fill="none">
                    <path d="m14.1 14.1 3.4 3.4" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" />
                    <circle cx="8.7" cy="8.7" r="5.7" stroke="currentColor" stroke-width="1.7" />
                  </svg>
                </span>
                <input type="text" inputmode="search" enterkeyhint="search" role="searchbox" data-ref="search" placeholder="Search scripts" autocomplete="off" spellcheck="false" />
              </mm-input>
              <mm-select>
                <input type="hidden" data-ref="filter" value="all" />
                <button type="button" class="mm-select-trigger" data-ref="select-trigger" aria-haspopup="listbox" aria-expanded="false">
                  <span class="mm-select-value" data-ref="select-value">All scripts</span>
                  <%- include('../partials/mm-select-chevron') %>
                </button>
                <div class="mm-select-menu" role="listbox">
                  <button type="button" class="mm-select-option" data-value="all" aria-selected="true">All scripts</button>
                  <button type="button" class="mm-select-option" data-value="installed" aria-selected="false">Installed only</button>
                  <button type="button" class="mm-select-option" data-value="uninstalled" aria-selected="false">Uninstalled only</button>
                </div>
              </mm-select>
              <mm-search-select
                class="mm-scripts-service-filter"
                data-ref="service-select"
                placeholder="All services"
                search-placeholder="Search services..."
              ></mm-search-select>
            </div>
          </div>

          <div class="mm-scripts-body">
            <div data-ref="empty" class="mm-scripts-empty hidden"></div>
            <div data-ref="error" class="mm-scripts-error hidden" role="alert"></div>

            <div data-ref="skeleton" class="mm-scripts-skeleton" aria-busy="true" aria-label="Loading scripts">
              <div class="mm-scripts-table-head mm-scripts-skeleton-head" role="row">
                <%- include('./scripts-table-head-cells') %>
              </div>
              <div class="mm-scripts-skeleton-rows">
                <%- include('./scripts-skeleton-row') %>
                <%- include('./scripts-skeleton-row') %>
                <%- include('./scripts-skeleton-row') %>
                <%- include('./scripts-skeleton-row') %>
                <%- include('./scripts-skeleton-row') %>
                <%- include('./scripts-skeleton-row') %>
                <%- include('./scripts-skeleton-row') %>
                <%- include('./scripts-skeleton-row') %>
                <%- include('./scripts-skeleton-row') %>
                <%- include('./scripts-skeleton-row') %>
              </div>
            </div>

            <div data-ref="list-head" class="mm-scripts-table-head hidden" role="row" aria-hidden="true">
              <%- include('./scripts-table-head-cells') %>
            </div>

            <div data-ref="scroll-shell" class="mm-scripts-table-scroll-shell hidden">
              <div data-ref="scroller" class="mm-scripts-table-scroll">
                <div data-ref="content" class="mm-scripts-list-content"></div>
              </div>
              <div data-ref="scrollbar" class="mm-scripts-scrollbar" aria-hidden="true">
                <span data-ref="scrollbar-thumb" class="mm-scripts-scrollbar-thumb"></span>
              </div>
            </div>
          </div>

          <footer class="mm-scripts-footer hidden" data-ref="footer" aria-live="polite"></footer>
        </div>
