                </div>
                <div class="mm-script-skeleton-row" aria-hidden="true">
                  <span class="mm-skeleton mm-skeleton-index"></span><span class="mm-skeleton mm-skeleton-name"></span><span class="mm-skeleton mm-skeleton-file"></span><span class="mm-skeleton mm-skeleton-service"></span
                  ><span class="mm-skeleton mm-skeleton-rules"></span
                  ><span class="mm-skeleton mm-skeleton-switch"></span>
                </div>
                <div class="mm-script-skeleton-row" aria-hidden="true">
                  <span class="mm-skeleton mm-skeleton-index"></span><span class="mm-skeleton mm-skeleton-name"></span><span class="mm-skeleton mm-skeleton-file"></span><span class="mm-skeleton mm-skeleton-service"></span
                  ><span class="mm-skeleton mm-skeleton-rules"></span
                  ><span class="mm-skeleton mm-skeleton-switch"></span>
                </div>
