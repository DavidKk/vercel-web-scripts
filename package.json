{
  "name": "magickmonkey",
  "version": "0.1.0",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/DavidKk/vercel-web-scripts"
  },
  "scripts": {
    "commit": "git-cz",
    "postinstall": "node --experimental-modules ./scripts/postinstall.mjs && node scripts/generate-editor-typings.mjs",
    "preinstall": "node --experimental-modules ./scripts/preinstall.mjs",
    "format": "prettier --config .prettierrc.js --write \"**/*.{js,jsx,ts,tsx,d.ts,vue,md,json,yml,yaml}\"",
    "lint": "pnpm lint:ts",
    "lint:ts": "eslint -c eslint.config.mjs --fix .",
    "typecheck": "tsc --noEmit && pnpm run typecheck:preset && pnpm run typecheck:extension && pnpm run typecheck:editor-lib",
    "typecheck:preset": "cd preset && tsc --noEmit",
    "typecheck:extension": "cd extension && tsc --noEmit",
    "typecheck:editor-lib": "cd editor-lib && tsc --noEmit",
    "dev": "pnpm run build:preset && pnpm run build:editor-lib && pnpm run build:extension:icons && concurrently -n next,preset,extension \"next dev --webpack\" \"pnpm run build:preset:dev\" \"pnpm run build:extension:dev\"",
    "build": "pnpm run build:preset && pnpm run build:editor-lib && pnpm run pack:extension && next build --webpack",
    "start": "next start",
    "test": "jest -c ./jest.config.ts --coverage --reporters=default --reporters=jest-junit --passWithNoTests",
    "test:watch": "jest --watch",
    "ok": "pnpm format && pnpm lint && pnpm typecheck && pnpm test",
    "test:e2e": "pnpm run build:preset && playwright test --reporter=list",
    "test:e2e:clean-browsers": "playwright uninstall --all",
    "test:e2e:install": "playwright install chromium",
    "dev:e2e": "next dev --webpack --hostname 127.0.0.1 --port 3000",
    "generate:editor-typings": "node scripts/generate-editor-typings.mjs",
    "build:preset": "vite build --config preset/vite.config.ts && vite build --config preset/vite.ui.config.ts",
    "build:editor-lib": "vite build --config editor-lib/vite.config.ts",
    "build:preset:dev": "concurrently -n preset-core,preset-ui,editor-lib \"vite build --config preset/vite.config.ts --watch\" \"vite build --config preset/vite.ui.config.ts --watch\" \"vite build --config editor-lib/vite.config.ts --watch\"",
    "build:extension:icons": "node extension/scripts/build-icons.mjs",
    "build:extension": "pnpm run build:extension:icons && vite build --config extension/vite.config.ts",
    "build:extension:dev": "vite build --config extension/vite.config.ts --watch",
    "pack:extension": "pnpm run build:extension && node extension/scripts/pack-extension-zip.mjs",
    "test:extension:static-watch": "node extension/scripts/verify-static-watch.mjs",
    "prepare": "husky"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@iconify-json/mdi": "^1.2.3",
    "@monaco-editor/react": "^4.7.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vercel/analytics": "^1.5.0",
    "@vercel/speed-insights": "^1.2.0",
    "ahooks": "^3.8.4",
    "cookie": "^1.0.2",
    "next": "16.1.4",
    "otplib": "^12.0.1",
    "prettier": "^3.4.2",
    "puppeteer": "^24.2.1",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-icons": "^5.5.0",
    "ts-morph": "^26.0.0",
    "typescript": "^5.7.2",
    "unplugin-icons": "^23.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@codemirror/commands": "^6.8.1",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.9",
    "@codemirror/lang-javascript": "^6.2.4",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.3.3",
    "@codemirror/language": "^6.11.2",
    "@codemirror/search": "^6.5.11",
    "@codemirror/state": "^6.5.2",
    "@codemirror/view": "^6.38.0",
    "@lezer/highlight": "^1.2.1",
    "@commitlint/cli": "^19.3.0",
    "@commitlint/config-conventional": "^19.2.2",
    "@eslint/eslintrc": "^3",
    "@jest/types": "^29.6.3",
    "@playwright/test": "^1.56.1",
    "@types/chrome": "^0.0.287",
    "@types/chalk": "^2.2.0",
    "@types/jest": "^29.5.12",
    "@types/node": "^20",
    "@typescript-eslint/eslint-plugin": "^7.16.1",
    "@typescript-eslint/parser": "^7.16.1",
    "chalk": "^5.3.0",
    "commitizen": "^4.2.4",
    "commitlint-plugin-i18n": "^0.0.1-alpha.3",
    "concurrently": "^9.1.2",
    "cz-customizable": "^7.2.1",
    "cz-customizable-i18n-config": "^0.0.1-alpha.2",
    "ejs": "^3.1.10",
    "eslint": "^9",
    "eslint-config-next": "16.1.4",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-import": "^2.29.0",
    "eslint-plugin-prettier": "^5.2.1",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-junit": "^16.0.0",
    "jest-runner-tsd": "^6.0.0",
    "json5": "^2.2.3",
    "lint-staged": "^15.2.7",
    "postcss": "^8",
    "prettier": "^3.4.2",
    "pretty-error": "^4.0.0",
    "rimraf": "^6.0.1",
    "spinnies": "^0.5.1",
    "tailwindcss": "^3.4.1",
    "ts-jest": "^29.2.3",
    "ts-node": "^10.9.2",
    "ts-patch": "^3.2.1",
    "tsd-lite": "^0.9.0",
    "typescript": "^5.7.2",
    "typescript-transform-paths": "^3.4.7",
    "vite": "^6.0.0"
  },
  "packageManager": "pnpm@11.5.0+sha512.dbfcc4f81cf48597afd4bc391ffdf12c11f1a9fb83a395bfa6b0a2d9cc2fd8ffebafdb1ccbd529632153f793904c2615b7f09fe1a345473fd1c35845172a8eb1"
}
